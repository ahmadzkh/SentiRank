# Raw datasets must stay local
datasets/raw/*
!datasets/raw/.gitkeep

# Processed datasets ignored by default
datasets/processed/*
!datasets/processed/.gitkeep

# External resources ignored by default
datasets/external/*
!datasets/external/.gitkeep

# Generated outputs ignored by default
datasets/outputs/*
!datasets/outputs/.gitkeep

# Allow aggregate EDA metrics for frontend/dashboard
!datasets/outputs/eda/
!datasets/outputs/eda/**

# Ignore trained model artifacts
ml-service/saved_models/**/*
!ml-service/saved_models/**/
!ml-service/saved_models/**/.gitkeep

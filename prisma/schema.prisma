generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Review {
  id           String    @id @default(cuid())
  source       String?
  externalId   String?
  authorName   String?
  rating       Int?
  content      String
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sentimentResult SentimentAnalysisResult?
  aspectResult    AspectClassificationResult?

  @@index([source])
  @@index([externalId])
  @@index([rating])
  @@index([reviewedAt])
}

model SentimentAnalysisResult {
  id          String   @id @default(cuid())
  reviewId    String   @unique
  label       String
  confidence  Float?
  modelName   String?
  modelVersion String?
  analyzedAt  DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([label])
  @@index([modelName])
}

model AspectClassificationResult {
  id           String   @id @default(cuid())
  reviewId     String   @unique
  aspect       String
  confidence   Float?
  modelName    String?
  modelVersion String?
  classifiedAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([aspect])
  @@index([modelName])
}

model ModelEvaluationSummary {
  id           String   @id @default(cuid())
  modelName    String
  modelType    String
  datasetSplit String?
  accuracy     Float?
  precision    Float?
  recall       Float?
  f1Score      Float?
  notes        String?
  evaluatedAt  DateTime @default(now())

  @@index([modelType])
  @@index([modelName])
  @@index([evaluatedAt])
}

model AhpWeight {
  id               String   @id @default(cuid())
  runLabel         String   @default("default")
  criterion        String
  weight           Float
  consistencyRatio Float?
  computedAt       DateTime @default(now())

  @@index([runLabel])
  @@index([criterion])
}

model FuzzyAhpWeight {
  id         String   @id @default(cuid())
  runLabel   String   @default("default")
  criterion  String
  weight     Float
  lowerBound Float?
  upperBound Float?
  computedAt DateTime @default(now())

  @@index([runLabel])
  @@index([criterion])
}

model AhpRankingResult {
  id           String   @id @default(cuid())
  runLabel     String   @default("default")
  priorityArea String
  score        Float
  rank         Int
  generatedAt  DateTime @default(now())

  @@index([runLabel])
  @@index([rank])
  @@index([priorityArea])
}

model FuzzyAhpRankingResult {
  id           String   @id @default(cuid())
  runLabel     String   @default("default")
  priorityArea String
  score        Float
  rank         Int
  generatedAt  DateTime @default(now())

  @@index([runLabel])
  @@index([rank])
  @@index([priorityArea])
}

model RankingComparisonResult {
  id            String   @id @default(cuid())
  runLabel      String   @default("default")
  priorityArea  String
  ahpScore      Float?
  fuzzyAhpScore Float?
  ahpRank       Int?
  fuzzyAhpRank  Int?
  rankDelta     Int?
  generatedAt   DateTime @default(now())

  @@index([runLabel])
  @@index([priorityArea])
  @@index([ahpRank])
  @@index([fuzzyAhpRank])
}
